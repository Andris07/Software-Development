<Window x:Class="Randemúúú.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:local="clr-namespace:Randemúúú"
        mc:Ignorable="d"
        Title="Randemúúú" Height="720" Width="1280">
    <Grid >
        <Grid.Background>
            <ImageBrush ImageSource="/hearts.jpg" Stretch="UniformToFill"/>
        </Grid.Background>
        
        <Grid
            x:Name="Form"
            Background="#7FFFFFFF"
            Width="400"
            Height="600"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Margin="10,10,10,10"
        >
            <StackPanel>
                <TextBlock
                    x:Name="Title"
                    Text="Randemúúú"
                    Background="#7F000000"
                    Foreground="#FFFF0096"
                    Width="350"
                    Height="50"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="10,10,10,10"
                    Padding="5,5,5,5"
                    FontFamily="Impact"
                    FontSize="36"
                    FontStyle="Italic"
                    TextAlignment="Center"
                />

                <Ellipse x:Name="Logo" Width="200" Height="100" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,10,10,10">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="/couple.jpg" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Vezetéknév -->
                <TextBlock
                    x:Name="LastName"
                    Text="Vezetéknév:"
                    Foreground="White"
                    Width="150"
                    Height="25"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="5,3,5,3"
                    FontFamily="Arial Black"
                    FontSize="16"
                    TextAlignment="Center"
                />
                <TextBox
                    x:Name="LastNameTextBox"
                    Background="#7FFF0096"
                    BorderBrush="White"
                    CaretBrush="White"
                    Foreground="White"
                    SelectionBrush="#FFFF0096"
                    SelectionTextBrush="White"
                    Width="300"
                    Height="25"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,0,0,3"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    FontFamily="Arial Black"
                    FontSize="16"
                    TextAlignment="Center"
                />

                <!-- Keresztnév -->
                <TextBlock
                    x:Name="FirstName"
                    Text="Keresztnév:"
                    Foreground="White"
                    Width="150"
                    Height="25"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="5,3,5,3"
                    FontFamily="Arial Black"
                    FontSize="16"
                    TextAlignment="Center"
                />
                <TextBox
                    x:Name="FirstNameTextBox"
                    Background="#7FFF0096"
                    BorderBrush="White"
                    CaretBrush="White"
                    Foreground="White"
                    SelectionBrush="#FFFF0096"
                    SelectionTextBrush="White"
                    Width="300"
                    Height="25"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,0,0,3"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    FontFamily="Arial Black"
                    FontSize="16"
                    TextAlignment="Center"
                />
                
                <!-- Kor -->
                <TextBlock
                    x:Name="Age"
                    Text="Kor:"
                    Foreground="White"
                    Width="150"
                    Height="25"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="5,3,5,3"
                    FontFamily="Arial Black"
                    FontSize="16"
                    TextAlignment="Center"
                />
                <xctk:IntegerUpDown
                    x:Name="AgeInput"
                    Minimum="18"
                    Maximum="100"
                    Value="18"
                    Background="#7FFF0096"
                    BorderBrush="White"
                    CaretBrush="White"
                    Foreground="White"
                    Width="300"
                    Height="25"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,0,0,3"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    FontFamily="Arial Black"
                    FontSize="16"
                    TextAlignment="Center"
                />

                <!-- Nem -->
                <TextBlock
                    x:Name="Gender"
                    Text="Nem:"
                    Foreground="White"
                    Width="150"
                    Height="25"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="5,3,5,3"
                    FontFamily="Arial Black"
                    FontSize="16"
                    TextAlignment="Center"
                />
                <Grid
                    x:Name="GenderRadio"
                    Background="#7FFF0096"
                    Width="300"
                    Height="25"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,3"
                >
                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                    >
                        <RadioButton
                            x:Name="MaleRadio"
                            Content="Férfi"
                            GroupName="Gender"
                            Foreground="White"
                            FontFamily="Arial Black"
                            FontSize="14"
                            Margin="0,0"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                        />
                        <RadioButton
                            x:Name="FemaleRadio"
                            Content="Nő"
                            GroupName="Gender"
                            Foreground="White"
                            FontFamily="Arial Black"
                            FontSize="14"
                            Margin="10,0"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                        />
                    </StackPanel>
                </Grid>

                <!-- Telefonszám -->
                <TextBlock
                    x:Name="TelephoneNumber"
                    Text="Telefonszám:"
                    Foreground="White"
                    Width="150"
                    Height="25"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="5,3,5,3"
                    FontFamily="Arial Black"
                    FontSize="16"
                    TextAlignment="Center"
                />
                <TextBox
                    x:Name="TelephoneNumberTextBox"
                    Background="#7FFF0096"
                    BorderBrush="White"
                    CaretBrush="White"
                    Foreground="White"
                    SelectionBrush="#FFFF0096"
                    SelectionTextBrush="White"
                    Width="300"
                    Height="25"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,0,0,3"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    FontFamily="Arial Black"
                    FontSize="16"
                    TextAlignment="Center"
                />
                
                <!-- Email -->
                <TextBlock
                    x:Name="Email"
                    Text="Email:"
                    Foreground="White"
                    Width="150"
                    Height="25"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="5,3,5,3"
                    FontFamily="Arial Black"
                    FontSize="16"
                    TextAlignment="Center"
                />
                <TextBox
                    x:Name="EmailTextBox"
                    Background="#7FFF0096"
                    BorderBrush="White"
                    CaretBrush="White"
                    Foreground="White"
                    SelectionBrush="#FFFF0096"
                    SelectionTextBrush="White"
                    Width="300"
                    Height="25"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,0,0,3"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    FontFamily="Arial Black"
                    FontSize="16"
                    TextAlignment="Center"
                />
                
                <!-- Regisztráció -->
                <Button
                    x:Name="Registration"
                    Content="Regisztráció"
                    Background="#FF0096"
                    BorderBrush="White"
                    BorderThickness="2"
                    Foreground="White"
                    Width="300"
                    Height="50"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,15,0,0"
                    FontFamily="Arial Black"
                    FontSize="16"
                    Cursor="Hand"
                    Click="Registration_Click"
                >
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="20"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                        >
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
