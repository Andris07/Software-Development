<Window x:Class="CsevegesGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CsevegesGUI"
        mc:Ignorable="d"
        Title="Csevegés GUI" Height="500" Width="400">
        <DockPanel Margin="20 30 30 20">
            <Grid DockPanel.Dock="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"></RowDefinition>
                </Grid.RowDefinitions>

                <Label Grid.Column="0" Content="Kezdeményező"/>
                <ComboBox Grid.Column="1" Margin="15 0 0 0" x:Name="cbKezdemenyezo" SelectionChanged="Cseveges_SelectionChanged"/>
            </Grid>

            <Grid DockPanel.Dock="Top" Margin="0 5 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"></RowDefinition>
                </Grid.RowDefinitions>

                <Label Grid.Column="0" Content="Fogadó (partner)"/>
                <ComboBox Grid.Column="1" Margin="15 0 0 0" x:Name="cbFogado" SelectionChanged="Cseveges_SelectionChanged"/>
            </Grid>
            
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0 15 0 0">
                <Label Content="Csevegések"></Label>
            </StackPanel>
            
            <ListBox x:Name="CsevegesekListBox">
            
            </ListBox>
        </DockPanel>
</Window>
