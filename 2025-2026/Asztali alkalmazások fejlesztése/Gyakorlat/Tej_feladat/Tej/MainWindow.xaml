<Window x:Class="Tej.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tej"
        mc:Ignorable="d"
        Title="Tej" Height="600" Width="450">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/tej.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <DockPanel Background="#3F000000" Width="400" Height="550" HorizontalAlignment="Center" VerticalAlignment="Center" LastChildFill="False" Margin="10,10,10,10">
            <Border BorderBrush="Cyan" BorderThickness="1" Width="350" Height="25" DockPanel.Dock="Top" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,10,10,10" CornerRadius="10,10,10,10">
                <Border.Background>
                    <RadialGradientBrush>
                        <GradientStop Color="#7F00FFFF" Offset="0"></GradientStop>
                        <GradientStop Color="#7F00C8FF" Offset="1"></GradientStop>
                    </RadialGradientBrush>
                </Border.Background>
                <TextBlock TextWrapping="Wrap" Text="Tej és annak fajtái" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Impact" FontSize="24" FontWeight="Bold" FontStyle="Italic"/>
            </Border>

            <Border Background="#7FFFFFFF" BorderBrush="White" BorderThickness="5" Width="150" Height="450" DockPanel.Dock="Left" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,10,10,10" CornerRadius="10,10,10,10">
                <StackPanel HorizontalAlignment="Center" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <TextBlock TextWrapping="Wrap" Text="Tej Fajtái:" Foreground="White" HorizontalAlignment="Left" Margin="0,5,0,-5" FontFamily="Impact" FontSize="24" FontWeight="Bold" FontStyle="Italic"/>
                    <Separator Background="#FF00FFFF" Height="10" HorizontalContentAlignment="Center"/>

                    <TextBlock TextWrapping="Wrap" Text="Laktózmentes" Foreground="White" FontFamily="Impact" FontSize="16" FontStyle="Italic"/>
                    <Separator Background="White"/>

                    <TextBlock TextWrapping="Wrap" Text="Pasztőrözött" Foreground="White" FontFamily="Impact" FontSize="16" FontStyle="Italic"/>
                    <Separator Background="White"/>

                    <TextBlock TextWrapping="Wrap" Text="Ultramagas hőmérsékleten hőkezelt" Foreground="White" FontFamily="Impact" FontSize="16" FontStyle="Italic"/>
                    <Separator Background="White"/>

                    <TextBlock TextWrapping="Wrap" Text="Termosterilizált" Foreground="White" FontFamily="Impact" FontSize="16" FontStyle="Italic"/>
                    <Separator Background="White"/>

                    <TextBlock TextWrapping="Wrap" Text="Teljes" Foreground="White" FontFamily="Impact" FontSize="16" FontStyle="Italic"/>

                    <TextBlock TextWrapping="Wrap" Text="Tejek Általános Zsírtartalmai:" Foreground="White" HorizontalAlignment="Left" Margin="0,25,0,-5" FontFamily="Impact" FontSize="16" FontWeight="Bold" FontStyle="Italic"/>
                    <Separator Background="#FF00FFFF" Height="10" HorizontalContentAlignment="Center"/>

                    <TextBlock TextWrapping="Wrap" Text="1.5 százalékos" Foreground="White" FontFamily="Impact" FontSize="16" FontStyle="Italic"/>
                    <Separator Background="White"/>

                    <TextBlock TextWrapping="Wrap" Text="2.8 százalékos" Foreground="White" FontFamily="Impact" FontSize="16" FontStyle="Italic"/>
                    <Separator Background="White"/>

                    <TextBlock TextWrapping="Wrap" Text="3.5 százalékos" Foreground="White" FontFamily="Impact" FontSize="16" FontStyle="Italic"/>
                </StackPanel>
            </Border>

            <Border BorderBrush="White" BorderThickness="5" Width="200" Height="450" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10,10,10,10" CornerRadius="10,10,10,10">
                <Border.Background>
                    <ImageBrush x:Name="MilkBrush" ImageSource="/tejek.jpg" Stretch="UniformToFill"/>
                </Border.Background>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Button Content="1.5%" Width="50" Margin="5" Click="Milk15_Click"/>
                    <Button Content="2.8%" Width="50" Margin="5" Click="Milk28_Click"/>
                    <Button Content="3.5%" Width="50" Margin="5" Click="Milk35_Click"/>
                </StackPanel>
            </Border>
        </DockPanel>

        <Border Grid.Row="2" Background="#7F111111" BorderBrush="White" BorderThickness="3" Width="400" Height="25" VerticalAlignment="Bottom" Margin="0,0,0,17" Padding="1" CornerRadius="10">
            <TextBlock Text="Készítette: Laczkovics András Gergő 12.b" Foreground="White" FontFamily="Impact" FontSize="12" FontStyle="Italic" HorizontalAlignment="Center" TextAlignment="Center"/>
        </Border>
    </Grid>
</Window>
