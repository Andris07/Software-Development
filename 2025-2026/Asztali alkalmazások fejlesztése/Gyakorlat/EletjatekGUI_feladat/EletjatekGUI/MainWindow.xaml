<Window x:Class="EletjatekGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:EletjatekGUI.ViewModel"
        xmlns:local="clr-namespace:EletjatekGUI"
        mc:Ignorable="d"
        Title="Életjáték álláskészítő" Height="450" Width="800">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,20,0,0">
            <Label Content="Mátrix mérete [sor x oszlop]:" Margin="5,0,0,0"/>
            <ComboBox Margin="10,0,0,0" SelectedValue="{Binding Rows, Mode = TwoWay}" ItemsSource="{Binding Meretek}"/>
            <ComboBox Margin="5,0,0,0" SelectedValue="{Binding Columns, Mode = TwoWay}" ItemsSource="{Binding Meretek}"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,20,0,0">
            <Button Content="Üres mátrix létrehozása" Margin="5,0,0,0" Command="{Binding CreateNew}"/>
            <Button Content="Állás mentése" Margin="15,0,0,0" Command="{Binding Save}"/>
        </StackPanel>

        <UniformGrid Name="CheckBoxGrid" Margin="20,20,20,20" Rows="{Binding Rows}" Columns="{Binding Columns}"/>
    </DockPanel>
</Window>
