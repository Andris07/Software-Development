<Window x:Class="Jatek_Nyilvantartas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Jatek_Nyilvantartas"
        mc:Ignorable="d"
        Title="Játék nyilvántartó" Height="450" Width="800">
    <Grid Margin="10">
        <StackPanel x:Name="sp_Megjelenites">
            <ListBox x:Name="lb_Jatekok" Height="300" Width="650" HorizontalAlignment="Left" ScrollViewer.HorizontalScrollBarVisibility="Auto"/>

            <StackPanel Orientation="Horizontal"  Margin="0,10,0,0">
                <Button Content="Új játék hozzáadása" Width="150" Margin="0,0,10,0" Click="AddButton_Click"/>

                <Button Content="Törlés" Width="75" Click="DeleteButton_Click"/>
            </StackPanel>
        </StackPanel>

        <StackPanel x:Name="sp_Hozzaadas" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Cím:" Margin="0,0,48,0"/>
                <TextBox x:Name="TitleBox" Width="300"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Műfaj:"  Margin="0,0,34,0"/>
                <TextBox x:Name="GenreBox" Width="300"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="34,20,0,0">
                <Button Content="Mentés" Width="75" Margin="0,0,10,0" Click="SaveButton_Click"/>

                <Button Content="Mégsem" Width="75" Click="CancelButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
