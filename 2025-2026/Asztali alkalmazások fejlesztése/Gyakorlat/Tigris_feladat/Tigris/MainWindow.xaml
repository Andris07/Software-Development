<Window x:Class="Tigris.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tigris"
        mc:Ignorable="d"
        Title="Tigrisek" Height="450" Width="800" Icon="/tiger-icon.png">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/csikok.png"/>
        </Grid.Background>
        <DockPanel Margin="10,10,10,10">
            <Border BorderBrush="Black" BorderThickness="1" Height="80" DockPanel.Dock="Top"  CornerRadius="10,10,10,10" Margin="10,10,10,10">
                <Border.Background>
                    <RadialGradientBrush>
                        <GradientStop Color="Black" Offset="0"></GradientStop>
                        <GradientStop Color="White" Offset="1"></GradientStop>
                    </RadialGradientBrush>
                </Border.Background>
                <TextBlock TextWrapping="Wrap" Text="Tigrisek" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="36" FontFamily="Book Antiqua" Foreground="White" FontWeight="Bold"/>
            </Border>

            <Border BorderBrush="White" BorderThickness="1" DockPanel.Dock="Bottom" Height="30" CornerRadius="10,10,10,10" Margin="10,10,10,10" Background="Black">
                <TextBlock TextWrapping="Wrap" Text="Készítette: Laczkovics András Gergő" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
            </Border>
            
            <Border BorderBrush="Black" BorderThickness="1" DockPanel.Dock="Left" CornerRadius="10,10,10,10" Margin="10,10,10,10" Padding="10,10,10,10" Background="Black" Width="NaN">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" Text="Rendszertani besorolás" Foreground="White" FontSize="18"/>
                    <Separator Width="NaN"/>
                    
                    <TextBlock TextWrapping="Wrap" Text="Text1" Foreground="White"/>
                    <Separator/>
                    
                    <TextBlock TextWrapping="Wrap" Text="Ország: Állatok" Foreground="White"/>
                    <Separator/>
                    
                    <TextBlock TextWrapping="Wrap" Text="Törzs: Gerinchúrosok" Foreground="White"/>
                    <Separator/>
                    
                    <TextBlock TextWrapping="Wrap" Text="Osztály: Emlősök" Foreground="White"/>
                    <Separator/>
                    
                    <TextBlock TextWrapping="Wrap" Text="Rend: Ragadozók" Foreground="White"/>
                    <Separator/>
                    
                    <TextBlock TextWrapping="Wrap" Text="Család: Macskafélék" Foreground="White"/>
                    <Separator/>
                    
                    <TextBlock TextWrapping="Wrap" Text="Alcsalád: Párducformák" Foreground="White"/>
                </StackPanel>
            </Border>
            
            <Border BorderBrush="Black" BorderThickness="1" DockPanel.Dock="Top" Background="Black" CornerRadius="10,10,10,10" Margin="10,10,10,0" Padding="5,5,5,8" Height="NaN">
                <TextBlock TextWrapping="Wrap" Text="Alfajok" Foreground="White" FontSize="18" HorizontalAlignment="Center"/>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <WrapPanel>
                    <StackPanel Background="White" Margin="5,5,5,5">
                        <Image Height="100" Width="150" Source="/bengali.jpg" Margin="10,10,10,0"/>
                        <TextBlock TextWrapping="Wrap" Text="Bengáli tigris" HorizontalAlignment="Center" Padding="10,5,10,5"/>
                    </StackPanel>
                    
                    <StackPanel Background="White" Margin="5,5,5,5">
                        <Image Height="100" Width="150" Source="/sziberiai.jpg" Margin="10,10,10,0"/>
                        <TextBlock TextWrapping="Wrap" Text="Szibériai tigris" HorizontalAlignment="Center" Padding="10,5,10,5"/>
                    </StackPanel>
                    
                    <StackPanel Background="White" Margin="5,5,5,5">
                        <Image Height="100" Width="150" Source="/malaj.jpg" Margin="10,10,10,0"/>
                        <TextBlock TextWrapping="Wrap" Text="Maláj tigris" HorizontalAlignment="Center" Padding="10,5,10,5"/>
                    </StackPanel>
                </WrapPanel>
            </ScrollViewer>
        </DockPanel>

    </Grid>
</Window>
