<Window x:Class="NyelviskolaGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NyelviskolaGUI"
        mc:Ignorable="d"
        Title="Nyelvtanárok adatai" Height="450" Width="800">
    <DockPanel Margin="20">
        <Label Content="Kérem válasszon nyelvet:" DockPanel.Dock="Top"/>
        <ComboBox x:Name="cb_nyelv" DockPanel.Dock="Top" SelectionChanged="cb_nyelv_SelectionChanged"/>

        <Label Content="Kérem válasszon tanárt:" DockPanel.Dock="Top" Margin="0,20,0,0"/>
        <ComboBox x:Name="cb_tanar" IsEnabled="False" DockPanel.Dock="Top" SelectionChanged="cb_tanar_SelectionChanged"/>

        <Grid x:Name="grid_adatok" Visibility="Hidden">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition Height="auto" MinHeight="20"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="auto" MinHeight="20"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="auto" MinHeight="20"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="auto" MinHeight="20"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="auto" MinHeight="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Label Content="Telefon:" Grid.Row="1"/>
            <TextBox x:Name="t_telefon" IsReadOnly="True" Grid.Row="1" Grid.Column="1"/>

            <Label Content="Email:" Grid.Row="3"/>
            <TextBox x:Name="t_email" IsReadOnly="True" Grid.Row="3" Grid.Column="1"/>

            <Label Content="Óradíj:" Grid.Row="5"/>
            <TextBox x:Name="t_oradij" IsReadOnly="True" Grid.Row="5" Grid.Column="1"/>
            <Label Content="Ft" Grid.Row="5" Grid.Column="2"/>

            <Label Content="Online óra:" Grid.Row="7"/>
            <CheckBox x:Name="chb_online" IsEnabled="False" Grid.Row="7" Grid.Column="1"/>
        </Grid>
    </DockPanel>
</Window>
