<Window x:Class="WpfApp_elso.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp_elso"
        mc:Ignorable="d"
        Title="Első demó program" Height="450" Width="800">
    <Canvas>
        <Button x:Name="button" Content="Button" Canvas.Left="200" Canvas.Top="50" Height="50" Width="150" Background="Aqua" BorderBrush="Navy" Click="Button_Click"/>
        <ListBox x:Name="listBox" Height="150" Canvas.Left="200" Canvas.Top="125" Width="200" d:ItemsSource="{d:SampleData ItemCount=5}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

    </Canvas>
</Window>
